# Caddyfile — конфиг reverse proxy для прода.
#
# Caddy делает три вещи «из коробки», для которых nginx нужно настраивать вручную:
#   1. Получает TLS-сертификат Let's Encrypt при первом запросе к домену
#      (ACME HTTP-01 challenge: LE обращается на http://ДОМЕН/.well-known/... —
#      поэтому DNS-запись должна указывать на сервер ДО старта Caddy).
#   2. Автоматически продлевает сертификат (хранит его в volume /data).
#   3. Редиректит http:// → https:// сам, без отдельного server-блока.
#
# {$DOMAIN} — подстановка переменной окружения контейнера (задаётся в compose
# из .env). Так домен живёт в одном месте — .env, рядом с BASE_URL.

{$DOMAIN} {
	# Проксируем всё приложению. "app" — имя сервиса в compose-сети,
	# 8000 — внутренний порт uvicorn (наружу он на проде не публикуется).
	# Caddy сам добавляет заголовок X-Forwarded-For с реальным IP клиента —
	# его читает uvicorn (--proxy-headers), чтобы rate-limiter видел клиентов,
	# а не IP прокси.
	reverse_proxy app:8000
}
