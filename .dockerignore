# Что НЕ копировать в образ при `COPY . .`
# Работает как .gitignore, но для docker build.
# Две цели: 1) меньше «контекст сборки» → быстрее сборка и меньше образ;
#           2) не утащить в образ секреты и мусор.

# Виртуальное окружение хоста — в контейнере создаётся своё,
# бинарники с Windows всё равно не заработают в Linux
.venv/

# Git-история не нужна приложению, а весит много
.git/
.gitignore
.gitattributes

# Секреты! .env никогда не должен попадать в образ —
# конфиг передаётся через переменные окружения при запуске
.env

# Кэши инструментов
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.coverage

# Тесты и docker-файлы приложению в рантайме не нужны
tests/
docker-compose*.yml
Dockerfile
.dockerignore

# Данные локального Postgres (если вдруг лежат рядом)
pgdata/

# Документация и служебные файлы
README.md
CLAUDE.md
DECISIONS.md
.claude/
