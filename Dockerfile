# Dockerfile v1 — простейший рабочий вариант (одна стадия).
# На шаге 2 улучшим: multi-stage, кэширование слоёв, non-root.

# Базовый образ: официальный Python. Вариант -slim — Debian без лишних пакетов
# (~120 МБ вместо ~1 ГБ у полного). Alpine не берём: у него musl вместо glibc,
# из-за чего готовые wheel-пакеты (asyncpg, bcrypt) могут не встать.
FROM python:3.13-slim

# Ставим uv, просто копируя готовый бинарник из официального образа Astral.
# Это быстрее и надёжнее, чем curl | sh. Версию пиним = локальной (0.11.6),
# чтобы сборка была воспроизводимой.
COPY --from=ghcr.io/astral-sh/uv:0.11.6 /uv /uvx /bin/

# Все дальнейшие команды выполняются из /app (аналог cd)
WORKDIR /app

# Копируем проект внутрь образа (что именно — фильтрует .dockerignore)
COPY . .

# Ставим зависимости.
# --frozen  — строго по uv.lock, без пересчёта версий (воспроизводимость)
# --no-dev  — без dev-группы (ruff в проде не нужен)
# Группа test тоже не ставится: uv ставит только default-группы.
RUN uv sync --frozen --no-dev

# Документируем, какой порт слушает приложение
# (сам по себе EXPOSE ничего не открывает — это метка для человека и инструментов)
EXPOSE 8000

# Команда по умолчанию при старте контейнера.
# --host 0.0.0.0 обязателен: localhost внутри контейнера недоступен снаружи.
# --no-sync — не перепроверять зависимости при старте, они уже установлены.
CMD ["uv", "run", "--no-sync", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
