# Шаблон переменных окружения.
# Скопируй в .env и подставь свои значения:  cp .env.example .env
# Файл .env в git НЕ попадает (см. .gitignore) — там реальные секреты.

# --- База данных (PostgreSQL) ---
# Формат: postgresql+asyncpg://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД
# Гибридный dev-режим (app через uv, БД в Docker): хост localhost, порт 5434.
# Внутри docker compose приложение использует хост db:5432 — это задаётся в compose,
# а не здесь (см. docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5434/link_shortener

# --- Безопасность (понадобится на этапе авторизации) ---
# Секрет для подписи JWT-токенов. Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# --- Приложение ---
# Базовый адрес сервиса — из него строим короткие ссылки (BASE_URL/{code})
BASE_URL=http://localhost:8000

# Логировать SQL-запросы в консоль (удобно при отладке). По умолчанию выключено.
# DB_ECHO=true

# Origin'ы для CORS (через запятую) — нужно только в dev, когда фронт (vite,
# порт 5173) обращается к API (uvicorn, порт 8000) напрямую, без общего домена.
# CORS_ORIGINS=http://localhost:5173

# --- Прод (docker compose -f docker-compose.yml -f docker-compose.prod.yml) ---
# На проде дефолтов нет: без этих переменных стек не поднимется (${VAR:?} в compose).
# Локально этот блок не нужен — базовый compose работает со своими дефолтами.
#
# POSTGRES_USER=app
# POSTGRES_PASSWORD=<сильный пароль: python3 -c "import secrets; print(secrets.token_urlsafe(24))">
# POSTGRES_DB=link_shortener
# SECRET_KEY=<python3 -c "import secrets; print(secrets.token_hex(32))">
# DOMAIN=s.faiuk.me
# BASE_URL=https://s.faiuk.me
